PORT=5000
NODE_ENV=production

# MySQL (use PlanetScale / Railway MySQL / Clever Cloud)
DB_HOST=your_mysql_host
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=debugging_agent

# JWT
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars
JWT_EXPIRES_IN=7d

# Groq AI (free at https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_groq_api_key

# CORS — comma-separated list of allowed frontend URLs
FRONTEND_URL=https://your-app.vercel.app,https://your-app.netlify.app
